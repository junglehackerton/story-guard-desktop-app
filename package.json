{
  "name": "story-guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n backend,frontend \"npm run backend\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "backend": ".venv/bin/python -m backend.app.main",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "cytoscape": "^3.30.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.4.0",
    "@types/cytoscape": "^3.21.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^4.1.9"
  },
  "description": "Story Guard is a local-first desktop MVP for Korean fiction writers. It imports drafts, builds a local RAG index, extracts story-world entities, renders an Obsidian-style graph, and reports continuity risks such as broken settings, timeline errors, and unresolved foreshadowing.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
